# Internal planning docs (not for public release)
/private_local/

# Frontend build artefacts -- regenerated by `make frontend-build`; embedded via
# //go:embed so the dist tree is tracked in git so `go build ./...` always
# succeeds without a prior frontend build step.
/internal/gui/dist/*.js
/internal/gui/dist/*.css

# TypeScript incremental build cache
frontend/tsconfig.tsbuildinfo


# Test media corpus (handled by Git LFS)
# Keeping *.mp4, *.mkv etc. in LFS via .gitattributes

# Benchmark results (tracked separately)
bench-*.txt

# Internal planning docs (not for public release)
/private_local/

# Frontend build artefacts -- regenerated by `make frontend-build`; embedded via
# //go:embed so there is no need to track them in git.
# The placeholder index.html is tracked so `go build ./...` always succeeds
# without a prior frontend build step.
/internal/gui/dist/assets/
/internal/gui/dist/*.js
/internal/gui/dist/*.css

# TypeScript incremental build cache
frontend/tsconfig.tsbuildinfo

# Stray pipeline / example processor output files when run from the repo root
/frame_info.jsonl
/scene_changes.jsonl
/detections.jsonl

docs/images/1.png
docs/images/2.png
docs/images/ABR.png
docs/images/Separate_audio_video.png


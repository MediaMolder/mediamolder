{
  "schema_version": "1.0",
  "description": "Wave 7 #41: amix filter — mix two audio sources (asplit fan-out then mix back).",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 },
        { "input_index": 0, "type": "audio", "track": 0 }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "asplit0",
        "type": "filter",
        "filter": "asplit",
        "params": { "_pos0": "2" }
      },
      {
        "id": "amix0",
        "type": "filter",
        "filter": "amix",
        "params": {
          "inputs": "2",
          "duration": "longest",
          "weights": "0.7 0.3"
        }
      },
      {
        "id": "chunk0",
        "type": "filter",
        "filter": "asetnsamples",
        "params": { "n": "1024", "p": "0" }
      }
    ],
    "edges": [
      { "from": "in0:v:0", "to": "out0:v", "type": "video" },
      { "from": "in0:a:0", "to": "asplit0", "type": "audio" },
      { "from": "asplit0", "to": "amix0", "type": "audio" },
      { "from": "asplit0", "to": "amix0", "type": "audio" },
      { "from": "amix0", "to": "chunk0", "type": "audio" },
      { "from": "chunk0", "to": "out0:a", "type": "audio" }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "copy",
      "codec_audio": "aac"
    }
  ]
}

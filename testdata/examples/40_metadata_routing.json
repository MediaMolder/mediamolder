{
  "schema_version": "1.1",
  "description": "Multi-source metadata routing via metadata_reader/metadata_writer graph nodes (Wave 2 #11). Single-input variant: container metadata is routed from in0 into out0 via an explicit graph node pair instead of the Input.MapMetadata shorthand. Mirrors `ffmpeg -i in.mp4 -map_metadata 0 -c copy out.mkv`.",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "meta_reader",
        "type": "metadata_reader",
        "params": {
          "source": "in0",
          "section": "global"
        }
      },
      {
        "id": "meta_writer",
        "type": "metadata_writer",
        "params": {
          "target": "out0",
          "section": "global"
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "out0:a",
        "type": "audio"
      },
      {
        "from": "meta_reader",
        "to": "meta_writer",
        "type": "metadata"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "format": "matroska",
      "codec_video": "copy",
      "codec_audio": "copy"
    }
  ]
}

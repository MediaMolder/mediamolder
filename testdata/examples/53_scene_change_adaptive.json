{
  "schema_version": "1.1",
  "description": "Decode in.mp4 -> detect scene changes using go-scene-detect AdaptiveDetector (rolling-window adaptive HSV ratio; adaptive_threshold 3.0, window_width 2, min_content_val 15.0) and write events to scene_changes_adaptive.jsonl -> encode to H.264, copy audio -> write to out.mp4. Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -i {{input}} -map 0:a:0 -map 0:v:0 -c:v libx264 -c:a copy -map_metadata 0 -map_chapters 0 {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "scene_detect",
        "type": "go_processor",
        "processor": "scene_change_adaptive",
        "params": {
          "output_file": "scene_changes_adaptive.jsonl",
          "adaptive_threshold": 3.0,
          "min_scene_len": 15,
          "window_width": 2,
          "min_content_val": 15.0,
          "luma_only": false
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "scene_detect:default",
        "type": "video"
      },
      {
        "from": "scene_detect:default",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "libx264",
      "codec_audio": "copy"
    }
  ]
}

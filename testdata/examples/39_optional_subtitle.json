{
  "schema_version": "1.1",
  "description": "Optional subtitle map: include subtitles if the source has any, otherwise pass through silently. (Wave 2 #9). Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -i {{input}} -map 0:a:0 -map 0:v:0 -c:v libx264 -c:a aac -map_metadata 0 -map_chapters 0 {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "subtitle",
          "all": true,
          "optional": true
        }
      ]
    }
  ],
  "graph": {
    "nodes": [],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "libx264",
      "codec_audio": "aac"
    }
  ]
}

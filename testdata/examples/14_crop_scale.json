{
  "schema_version": "1.0",
  "description": "Decode in.mp4 -> crop video to 640x480, downscale to 320x240, encode to H.264 with libx264, encode audio to AAC -> write to out.mp4",
  "inputs": [
    {
      "id": "in0",
      "url": "in.mp4",
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "crop0",
        "type": "filter",
        "filter": "crop",
        "params": {
          "w": "640",
          "h": "480"
        }
      },
      {
        "id": "scale0",
        "type": "filter",
        "filter": "scale",
        "params": {
          "w": "320",
          "h": "240"
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "crop0",
        "type": "video"
      },
      {
        "from": "crop0",
        "to": "scale0",
        "type": "video"
      },
      {
        "from": "scale0",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "out.mp4",
      "codec_video": "libx264",
      "codec_audio": "aac"
    }
  ]
}

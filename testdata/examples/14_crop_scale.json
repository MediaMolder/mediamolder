{
  "schema_version": "1.0",
  "description": "Decode in.mp4 -> crop video to 640x480, downscale to 320x240, encode to H.264 with libx264, encode audio to AAC -> write to out.mp4. Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -i {{input}} -filter_complex [0:v]crop=h=480:w=640[crop0];[crop0]scale=h=240:w=320[scale0] -map 0:a:0 -map 0:v:0 -c:v libx264 -c:a aac -map_metadata 0 -map_chapters 0 {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "crop0",
        "type": "filter",
        "filter": "crop",
        "params": {
          "w": "640",
          "h": "480"
        }
      },
      {
        "id": "scale0",
        "type": "filter",
        "filter": "scale",
        "params": {
          "w": "320",
          "h": "240"
        }
      },
      {
        "id": "enc_video",
        "type": "encoder",
        "params": {
          "codec": "libx264"
        }
      },
      {
        "id": "enc_audio",
        "type": "encoder",
        "params": {
          "codec": "aac"
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "crop0",
        "type": "video"
      },
      {
        "from": "crop0",
        "to": "scale0",
        "type": "video"
      },
      {
        "from": "scale0",
        "to": "enc_video",
        "type": "video"
      },
      {
        "from": "enc_video",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "enc_audio",
        "type": "audio"
      },
      {
        "from": "enc_audio",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}"
    }
  ]
}

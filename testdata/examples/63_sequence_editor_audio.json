{
  "schema_version": "1.1",
  "description": "sequence_editor with audio: two clips on one track joined by a dissolve, rendered to a fixed 1280x720@30 sequence with a mixed 48 kHz stereo audio stream. The clip's transition auto-crossfades the audio across the same window; here the curve is overridden to equal-power (qsin). The sequence_editor is a FrameSource that opens its sources directly, so its video output routes to the H.264 encoder and its audio output to the AAC encoder — no input->node edges are wired. (Both inputs point at the same fixture here; in real use they are distinct clips.)",
  "ffmpeg_cmd": "# No equivalent FFmpeg command — sequence_editor (node \"seq\") has no FFmpeg equivalent.",
  "inputs": [
    {
      "id": "clip_a",
      "url": "{{input}}",
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 },
        { "input_index": 0, "type": "audio", "track": 0 }
      ]
    },
    {
      "id": "clip_b",
      "url": "{{input}}",
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 },
        { "input_index": 0, "type": "audio", "track": 0 }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "seq",
        "type": "go_processor",
        "processor": "sequence_editor",
        "params": {
          "format": {
            "width": 1280,
            "height": 720,
            "pix_fmt": "yuv420p",
            "frame_rate": 30,
            "time_base": [1, 90000],
            "sample_rate": 48000,
            "channels": 2,
            "length_sec": 6
          },
          "tracks": [
            {
              "id": "V1",
              "type": "video",
              "clips": [
                { "input_id": "clip_a", "source_in": 0, "source_out": 3.5, "timeline_in": 0,
                  "transition": { "type": "dissolve", "duration": 1.0, "audio": { "curve": "qsin" } } },
                { "input_id": "clip_b", "source_in": 0, "source_out": 3.5, "timeline_in": 2.5 }
              ]
            }
          ]
        }
      },
      {
        "id": "venc",
        "type": "encoder",
        "params": { "codec": "libx264", "r": "30", "framerate": "30" }
      },
      {
        "id": "aenc",
        "type": "encoder",
        "params": { "codec": "aac", "b": "128000" }
      }
    ],
    "edges": [
      { "from": "seq",  "to": "venc",   "type": "video" },
      { "from": "seq",  "to": "aenc",   "type": "audio" },
      { "from": "venc", "to": "out0:v", "type": "video" },
      { "from": "aenc", "to": "out0:a", "type": "audio" }
    ]
  },
  "outputs": [
    { "id": "out0", "url": "{{output}}" }
  ]
}

{
  "schema_version": "1.1",
  "description": "Decode in.mp4 -> run YOLOv8 object detection on every 5th video frame using CUDA GPU -> encode to H.264, copy audio -> write to out.mp4. Reduces GPU load on high-fps streams while keeping all frames in the output.",
  "inputs": [
    {
      "id": "in0",
      "url": "",
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "detect0",
        "type": "go_processor",
        "processor": "yolo_v8",
        "params": {
          "model": "/models/yolov8n.onnx",
          "labels_file": "/models/coco.names",
          "device": "cuda",
          "process_every": 5,
          "conf": 0.4
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "detect0:default",
        "type": "video"
      },
      {
        "from": "detect0:default",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "",
      "codec_video": "libx264",
      "codec_audio": "copy"
    }
  ]
}

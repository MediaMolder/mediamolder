{
  "schema_version": "1.1",
  "description": "Decode in.mp4 -> log frame info (dimensions, pixel format, PTS) to frame_info.jsonl via metadata_file_writer -> encode to H.264, copy audio -> write to out.mp4.",
  "inputs": [
    {
      "id": "in0",
      "url": "",
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "info_logger",
        "type": "go_processor",
        "processor": "metadata_file_writer",
        "params": {
          "output_file": "frame_info.jsonl",
          "inner_processor": "frame_info",
          "log_every": 30
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "info_logger:default",
        "type": "video"
      },
      {
        "from": "info_logger:default",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "",
      "codec_video": "libx264",
      "codec_audio": "copy"
    }
  ]
}

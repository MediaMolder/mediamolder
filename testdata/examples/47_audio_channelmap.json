{
  "schema_version": "1.0",
  "description": "Wave 7 #41: channelmap filter — relabel stereo channels (swap L/R). Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -i {{input}} -filter_complex [0:a]channelmap=channel_layout=stereo:map=FR-FL|FL-FR[channelmap0];[channelmap0]asetnsamples=n=1024:p=0[chunk0] -map 0:a:0 -map 0:v:0 -c:v copy -c:a aac -map_metadata 0 -map_chapters 0 {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "channelmap0",
        "type": "filter",
        "filter": "channelmap",
        "params": {
          "map": "FR-FL|FL-FR",
          "channel_layout": "stereo"
        }
      },
      {
        "id": "chunk0",
        "type": "filter",
        "filter": "asetnsamples",
        "params": {
          "n": "1024",
          "p": "0"
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",

{
  "schema_version": "1.1",
  "description": "BBB_10sec.mp4 video → vf_metadata mode=add (inject mm.test=hello onto every AVFrame) → vf_metadata mode=print (dump all keys to frame_metadata.txt) → libx264 → mp4. Demonstrates that AVFrame->metadata propagates through libavfilter as a regular `filter` node — no new node kind is required for per-frame metadata (Wave 7 #39). The same pattern works for audio via `ametadata`.",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "addmd",
        "type": "filter",
        "filter": "metadata",
        "params": { "mode": "add", "key": "mm.test", "value": "hello" }
      },
      {
        "id": "printmd",
        "type": "filter",
        "filter": "metadata",
        "params": { "mode": "print", "file": "frame_metadata.txt" }
      }
    ],
    "edges": [
      { "from": "in0:v:0", "to": "addmd", "type": "video" },
      { "from": "addmd", "to": "printmd", "type": "video" },
      { "from": "printmd", "to": "out0:v", "type": "video" }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "format": "mp4",
      "codec_video": "libx264",
      "encoder_params_video": { "preset": "ultrafast", "crf": "30" }
    }
  ]
}

{
  "schema_version": "1.1",
  "description": "Decode in.mp4 -> detect scene changes (brightness + PTS gaps) and write to scene_changes.jsonl via metadata_file_writer -> encode to H.264, copy audio -> write to out.mp4.",
  "inputs": [
    {
      "id": "in0",
      "url": "in.mp4",
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "scene_detect",
        "type": "go_processor",
        "processor": "metadata_file_writer",
        "params": {
          "output_file": "scene_changes.jsonl",
          "inner_processor": "scene_change",
          "threshold": 10,
          "pts_threshold": 90000
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "scene_detect:default",
        "type": "video"
      },
      {
        "from": "scene_detect:default",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "out.mp4",
      "codec_video": "libx264",
      "codec_audio": "copy"
    }
  ]
}

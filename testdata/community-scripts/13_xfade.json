{
  "schema_version": "1.0",
  "description": "Apply an xfade transition between two clips (1 s 'fade' transition, offset 8 s into first clip). Matches 'xfade -a clip1.mp4 -b clip2.mp4 -d 1 -t fade -f 8 -o output.mp4'. Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -i {{input}} -i {{input2}} -filter_complex [0:v]fps=fps=24[fps_a];[1:v]fps=fps=24[fps_b];[fps_a][fps_b]xfade=duration=1:offset=8:transition=fade[xfade0];[0:a][1:a]acrossfade=d=1[acrossfade0];[acrossfade0]asetnsamples=n=1024:p=0[asetnsamples0] -map 0:a:0 -map 0:v:0 -map 1:a:0 -map 1:v:0 -c:v libx264 -c:a aac -map_metadata 0 -map_chapters 0 {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    },
    {
      "id": "in1",
      "url": "{{input2}}",
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "fps_a",
        "type": "filter",
        "filter": "fps",
        "params": {
          "fps": "24"
        }
      },
      {
        "id": "fps_b",
        "type": "filter",
        "filter": "fps",
        "params": {
          "fps": "24"
        }
      },
      {
        "id": "xfade0",
        "type": "filter",
        "filter": "xfade",
        "params": {
          "transition": "fade",
          "duration": "1",
          "offset": "8"
        }
      },
      {
        "id": "acrossfade0",
        "type": "filter",
        "filter": "acrossfade",
        "params": {
          "d": "1"
        }
      },
      {
        "id": "asetnsamples0",
        "type": "filter",
        "filter": "asetnsamples",
        "params": {
          "n": "1024",
          "p": "0"
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "fps_a",
        "type": "video"
      },
      {
        "from": "in1:v:0",
        "to": "fps_b",
        "type": "video"
      },
      {
        "from": "fps_a",
        "to": "xfade0",
        "type": "video"
      },
      {
        "from": "fps_b",
        "to": "xfade0",
        "type": "video"
      },
      {
        "from": "xfade0",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "acrossfade0",
        "type": "audio"
      },
      {
        "from": "in1:a:0",
        "to": "acrossfade0",
        "type": "audio"
      },
      {
        "from": "acrossfade0",
        "to": "asetnsamples0",
        "type": "audio"
      },
      {
        "from": "asetnsamples0",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "libx264",
      "codec_audio": "aac"
    }
  ]
}

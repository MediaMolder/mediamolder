{
  "schema_version": "1.0",
  "description": "Combine a video file with a separate audio file. Matches 'combine-clips -i video.mp4 -a audio.aac -o output.mp4'. Requires testdata/sample.aac fixture (see FIXTURES.md).",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 }
      ]
    },
    {
      "id": "in1",
      "url": "{{audio}}",
      "streams": [
        { "input_index": 0, "type": "audio", "track": 0 }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "asetnsamples0",
        "type": "filter",
        "filter": "asetnsamples",
        "params": { "n": "1024", "p": "0" }
      }
    ],
    "edges": [
      { "from": "in0:v:0", "to": "out0:v", "type": "video" },
      { "from": "in1:a:0", "to": "asetnsamples0", "type": "audio" },
      { "from": "asetnsamples0", "to": "out0:a", "type": "audio" }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "copy",
      "codec_audio": "aac"
    }
  ]
}

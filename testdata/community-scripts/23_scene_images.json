{
  "schema_version": "1.0",
  "description": "Capture the first detected scene-change frame as a JPEG. Matches 'scene-images -i input.mp4 -t 0.3 -o scene.jpg'. Multi-image (%03d) output is a separate roadmap item; this fixture validates the select+max_frames path. Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -i {{input}} -filter_complex [0:v]select=expr=gt(scene\\,0.3)[scene0];[scene0]format=pix_fmts=yuvj420p[fmt0] -map 0:v:0 -c:v mjpeg -pix_fmt:v yuvj420p -frames:v 1 -f mjpeg {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "scene0",
        "type": "filter",
        "filter": "select",
        "params": {
          "expr": "gt(scene\\,0.3)"
        }
      },
      {
        "id": "fmt0",
        "type": "filter",
        "filter": "format",
        "params": {
          "pix_fmts": "yuvj420p"
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "scene0",
        "type": "video"
      },
      {
        "from": "scene0",
        "to": "fmt0",
        "type": "video"
      },
      {
        "from": "fmt0",
        "to": "out0:v",
        "type": "video"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "format": "mjpeg",
      "codec_video": "mjpeg",
      "encoder_params_video": {
        "pix_fmt": "yuvj420p"
      },
      "max_frames_video": 1
    }
  ]
}

{
  "schema_version": "1.0",
  "description": "Convert a video clip to an animated GIF using palettegen + paletteuse for optimal quality. Matches 'vid2gif -s 00:00:00 -i input -t 00:00:05 -f 10 -w 320 -o output.gif'.",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "options": { "t": "5" },
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "fps0",
        "type": "filter",
        "filter": "fps",
        "params": { "fps": "10" }
      },
      {
        "id": "scale0",
        "type": "filter",
        "filter": "scale",
        "params": { "w": "320", "h": "-1", "flags": "lanczos" }
      },
      {
        "id": "format0",
        "type": "filter",
        "filter": "format",
        "params": { "pix_fmts": "bgr8" }
      }
    ],
    "edges": [
      { "from": "in0:v:0", "to": "fps0",    "type": "video" },
      { "from": "fps0",    "to": "scale0",  "type": "video" },
      { "from": "scale0",  "to": "format0", "type": "video" },
      { "from": "format0", "to": "out0:v",  "type": "video" }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "gif"
    }
  ]
}

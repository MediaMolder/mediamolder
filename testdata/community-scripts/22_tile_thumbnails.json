{
  "schema_version": "1.0",
  "description": "Build a contact sheet of evenly-spaced thumbnails using select+scale+tile, then write a single JPEG. Matches 'tile-thumbnails -i input.mp4 -n 16 -w 160 -o sheet.jpg'. Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -i {{input}} -filter_complex [0:v]select=expr=not(mod(n\\,15))[sel0];[sel0]scale=h=-1:w=160[scale0];[scale0]tile=layout=4x4[tile0];[tile0]format=pix_fmts=yuvj420p[fmt0] -map 0:v:0 -c:v mjpeg -pix_fmt:v yuvj420p -frames:v 1 -f mjpeg {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "sel0",
        "type": "filter",
        "filter": "select",
        "params": {
          "expr": "not(mod(n\\,15))"
        }
      },
      {
        "id": "scale0",
        "type": "filter",
        "filter": "scale",
        "params": {
          "w": "160",
          "h": "-1"
        }
      },
      {
        "id": "tile0",
        "type": "filter",
        "filter": "tile",
        "params": {
          "layout": "4x4"
        }
      },
      {
        "id": "fmt0",
        "type": "filter",
        "filter": "format",
        "params": {
          "pix_fmts": "yuvj420p"
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "sel0",
        "type": "video"
      },
      {
        "from": "sel0",
        "to": "scale0",
        "type": "video"
      },
      {
        "from": "scale0",
        "to": "tile0",
        "type": "video"
      },
      {
        "from": "tile0",
        "to": "fmt0",
        "type": "video"
      },
      {
        "from": "fmt0",
        "to": "out0:v",
        "type": "video"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "format": "mjpeg",
      "codec_video": "mjpeg",
      "encoder_params_video": {
        "pix_fmt": "yuvj420p"
      },
      "max_frames_video": 1
    }
  ]
}

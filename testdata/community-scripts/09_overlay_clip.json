{
  "schema_version": "1.0",
  "description": "Overlay one video clip on top of another (always-on, top-left). Matches 'overlay-clip -i bottom.mp4 -v overlay.mp4 -p 0 -o output.mp4'. Both inputs use testdata/BBB_10sec.mp4.",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 },
        { "input_index": 0, "type": "audio", "track": 0 }
      ]
    },
    {
      "id": "in1",
      "url": "{{input2}}",
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "overlay0",
        "type": "filter",
        "filter": "overlay",
        "params": { "x": "0", "y": "0" }
      }
    ],
    "edges": [
      { "from": "in0:v:0", "to": "overlay0",  "type": "video" },
      { "from": "in1:v:0", "to": "overlay0",  "type": "video" },
      { "from": "overlay0", "to": "out0:v",   "type": "video" },
      { "from": "in0:a:0",  "to": "out0:a",   "type": "audio" }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "libx264",
      "codec_audio": "copy"
    }
  ]
}

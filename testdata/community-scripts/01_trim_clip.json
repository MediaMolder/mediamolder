{
  "schema_version": "1.0",
  "description": "Trim a clip: seek to 00:00:02 and capture 5 seconds (stream copy). Matches 'trim-clip -s 00:00:02 -i input -t 00:00:05 -o output.mp4'.",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "options": { "ss": "00:00:02", "t": "5" },
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 },
        { "input_index": 0, "type": "audio", "track": 0 }
      ]
    }
  ],
  "graph": {
    "nodes": [],
    "edges": [
      { "from": "in0:v:0", "to": "out0:v", "type": "video" },
      { "from": "in0:a:0", "to": "out0:a", "type": "audio" }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "copy",
      "codec_audio": "copy"
    }
  ]
}

{
  "schema_version": "1.0",
  "description": "Normalize audio to EBU R128 target loudness with loudnorm filter; copy video. Matches 'loudnorm -i input.mp4'. Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -i {{input}} -filter_complex [0:a]loudnorm[loudnorm0];[loudnorm0]aformat=sample_fmts=fltp:sample_rates=48000[aformat0];[aformat0]asetnsamples=n=1024:p=0[asetnsamples0] -map 0:a:0 -map 0:v:0 -c:v copy -c:a aac -map_metadata 0 -map_chapters 0 {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "loudnorm0",
        "type": "filter",
        "filter": "loudnorm"
      },
      {
        "id": "aformat0",
        "type": "filter",
        "filter": "aformat",
        "params": {
          "sample_rates": "48000",
          "sample_fmts": "fltp"
        }
      },
      {
        "id": "asetnsamples0",
        "type": "filter",
        "filter": "asetnsamples",
        "params": {
          "n": "1024",
          "p": "0"
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "loudnorm0",
        "type": "audio"
      },
      {
        "from": "loudnorm0",
        "to": "aformat0",
        "type": "audio"
      },
      {
        "from": "aformat0",
        "to": "asetnsamples0",
        "type": "audio"
      },
      {
        "from": "asetnsamples0",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "copy",
      "codec_audio": "aac"
    }
  ]
}

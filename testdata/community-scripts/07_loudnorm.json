{
  "schema_version": "1.0",
  "description": "Normalize audio to EBU R128 target loudness with loudnorm filter; copy video. Matches 'loudnorm -i input.mp4'.",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [
        { "input_index": 0, "type": "video", "track": 0 },
        { "input_index": 0, "type": "audio", "track": 0 }
      ]
    }
  ],
  "graph": {
    "nodes": [
      {
        "id": "loudnorm0",
        "type": "filter",
        "filter": "loudnorm"
      },
      {
        "id": "aformat0",
        "type": "filter",
        "filter": "aformat",
        "params": { "sample_rates": "48000", "sample_fmts": "fltp" }
      },
      {
        "id": "asetnsamples0",
        "type": "filter",
        "filter": "asetnsamples",
        "params": { "n": "1024", "p": "0" }
      }
    ],
    "edges": [
      { "from": "in0:v:0",       "to": "out0:v",        "type": "video" },
      { "from": "in0:a:0",       "to": "loudnorm0",     "type": "audio" },
      { "from": "loudnorm0",     "to": "aformat0",      "type": "audio" },
      { "from": "aformat0",      "to": "asetnsamples0", "type": "audio" },
      { "from": "asetnsamples0", "to": "out0:a",        "type": "audio" }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "copy",
      "codec_audio": "aac"
    }
  ]
}

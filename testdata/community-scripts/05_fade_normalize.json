        "params": {
          "t": "out",
          "st": "8.5",
          "d": "0.5"
        }
      },
      {
        "id": "afade_in",
        "type": "filter",
        "filter": "afade",
        "params": {
          "t": "in",
          "st": "0",
          "d": "0.5"
        }
      },
      {
        "id": "afade_out",
        "type": "filter",
        "filter": "afade",
        "params": {
          "t": "out",
          "st": "9.0",
          "d": "0.5"
        }
      },
      {
        "id": "loudnorm0",

        "params": {
          "n": "1024",
          "p": "0"
        }
      }
    ],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "fade_in",
        "type": "video"
      },
      {
        "from": "fade_in",
        "to": "fade_out",
        "type": "video"
      },
      {
        "from": "fade_out",
        "to": "out0:v",

{
  "schema_version": "1.0",
  "description": "Fade video and audio in/out, then normalize audio loudness with loudnorm. Matches 'fade-normalize -i input -d 0.5 -o output.mp4'. Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -i {{input}} -filter_complex [0:v]fade=d=0.5:st=0:t=in[fade_in];[fade_in]fade=d=0.5:st=8.5:t=out[fade_out];[0:a]afade=d=0.5:st=0:t=in[afade_in];[afade_in]afade=d=0.5:st=9.0:t=out[afade_out];[afade_out]loudnorm[loudnorm0];[loudnorm0]aformat=sample_fmts=fltp:sample_rates=48000[aformat0];[aformat0]asetnsamples=n=1024:p=0[asetnsamples0] -map 0:a:0 -map 0:v:0 -c:v libx264 -c:a aac -map_metadata 0 -map_chapters 0 {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "streams": [

{
  "schema_version": "1.0",
  "description": "Re-encode a clip starting at a (scene-detected) timestamp, capping at N video frames via Output.MaxFramesVideo. Matches 'scene-cut -i input.mp4 -s 00:00:01 -t 00:00:03 -o cut.mp4' where the start time was previously found via scene detection. Combines input -ss/-t with -frames:v. Note: if you edit this JSON manually, you must also update or remove the ffmpeg_cmd field.",
  "ffmpeg_cmd": "ffmpeg -ss 1 -t 3 -i {{input}} -map 0:a:0 -map 0:v:0 -c:v libx264 -c:a aac -x264-params:v crf=30:preset=ultrafast -frames:v 30 -map_metadata 0 -map_chapters 0 {{output}}",
  "inputs": [
    {
      "id": "in0",
      "url": "{{input}}",
      "map_metadata": true,
      "map_chapters": true,
      "options": {
        "ss": "1",
        "t": "3"
      },
      "streams": [
        {
          "input_index": 0,
          "type": "video",
          "track": 0
        },
        {
          "input_index": 0,
          "type": "audio",
          "track": 0
        }
      ]
    }
  ],
  "graph": {
    "nodes": [],
    "edges": [
      {
        "from": "in0:v:0",
        "to": "out0:v",
        "type": "video"
      },
      {
        "from": "in0:a:0",
        "to": "out0:a",
        "type": "audio"
      }
    ]
  },
  "outputs": [
    {
      "id": "out0",
      "url": "{{output}}",
      "codec_video": "libx264",
      "encoder_params_video": {
        "preset": "ultrafast",
        "crf": "30"
      },
      "codec_audio": "aac",
      "max_frames_video": 30
    }
  ]
}

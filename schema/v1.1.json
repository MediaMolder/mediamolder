{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mediamolder.dev/schema/v1.1.json",
  "title": "MediaMolder Pipeline Config",
  "description": "Schema v1.1 for MediaMolder JSON pipeline configuration. Adds go_processor node type.",
  "type": "object",
  "required": ["schema_version", "inputs", "graph", "outputs"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0", "1.1"],
      "description": "\"1.0\" or \"1.1\". Use \"1.1\" when go_processor nodes are present."
    },
    "description": {
      "type": "string",
      "description": "Optional human-readable description of the pipeline job."
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/input" }
    },
    "graph": { "$ref": "#/$defs/graph" },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/output" }
    },
    "global_options": { "$ref": "#/$defs/global_options" }
  },
  "$defs": {
    "input": {
      "type": "object",
      "required": ["id", "url", "streams"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "streams": {
          "type": "array",
          "items": { "$ref": "#/$defs/stream_select" }
        },
        "options": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "stream_select": {
      "type": "object",
      "required": ["input_index", "type", "track"],
      "additionalProperties": false,
      "properties": {
        "input_index": { "type": "integer", "minimum": 0 },
        "type": {
          "type": "string",
          "enum": ["video", "audio", "subtitle", "data"]
        },
        "track": { "type": "integer", "minimum": 0 }
      }
    },
    "graph": {
      "type": "object",
      "required": ["nodes", "edges"],
      "additionalProperties": false,
      "properties": {
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge" }
        }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["filter", "encoder", "source", "sink", "go_processor"]
        },
        "filter": { "type": "string" },
        "processor": {
          "type": "string",
          "description": "Registered Go processor name (required for go_processor nodes)."
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "error_policy": { "$ref": "#/$defs/error_policy" }
      },
      "if": {
        "properties": { "type": { "const": "go_processor" } }
      },
      "then": {
        "required": ["id", "type", "processor"]
      }
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "type"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["video", "audio", "subtitle", "data"]
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["id", "url"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "format": { "type": "string" },
        "codec_video": { "type": "string" },
        "codec_audio": { "type": "string" },
        "codec_subtitle": { "type": "string" },
        "bsf_video": { "type": "string" },
        "bsf_audio": { "type": "string" },
        "options": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "global_options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "threads": { "type": "integer", "minimum": 0, "description": "Default codec thread count for all decoders/encoders. 0 = FFmpeg auto-detect. Can be overridden per node via params.threads." },
        "thread_type": { "type": "string", "enum": ["frame", "slice", "frame+slice"], "description": "Default codec threading model. Can be overridden per node via params.thread_type." },
        "hw_accel": { "type": "string" },
        "hw_device": { "type": "string" },
        "realtime": { "type": "boolean" }
      }
    },
    "error_policy": {
      "type": "object",
      "required": ["policy"],
      "additionalProperties": false,
      "properties": {
        "policy": {
          "type": "string",
          "enum": ["abort", "skip", "retry", "fallback"]
        },
        "max_retries": { "type": "integer", "minimum": 0 },
        "fallback_node": { "type": "string" }
      }
    }
  }
}
